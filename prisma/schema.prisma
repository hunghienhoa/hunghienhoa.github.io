generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model App {
  id               String      @id @default(cuid())
  slug             String      @unique
  name             String
  shortDescription String
  description      String
  categorySlug     String
  premium          Boolean     @default(false)
  featured         Boolean     @default(false)
  trending         Boolean     @default(false)
  rating           Float       @default(0)
  ratingCount      Int         @default(0)
  version          String
  size             String
  updatedAtLabel   String
  viewsLabel       String
  downloadsLabel   String
  iconLabel        String
  gradientStart    String
  gradientEnd      String
  tags             String[]
  screenshots      String[]
  compatibility    String[]
  hackFeatures     String[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  category         Category    @relation(fields: [categorySlug], references: [slug])
  developerId      String
  developer        Developer   @relation(fields: [developerId], references: [id])
  versions         Version[]
  downloads        Download[]
  comments         Comment[]
  favorites        Favorite[]
  reviews          Review[]
}

model Category {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String
  accent      String
  apps        App[]
}

model Developer {
  id        String @id @default(cuid())
  name      String
  slug      String @unique
  verified  Boolean @default(false)
  website   String
  apps      App[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Version {
  id             String   @id @default(cuid())
  label          String
  iosRequirement String
  fileSize       String
  latest         Boolean  @default(false)
  changelog      String[]
  appId          String
  app            App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Download {
  id          String   @id @default(cuid())
  type        String
  label       String
  description String
  url         String
  count       Int      @default(0)
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(cuid())
  author      String
  content     String
  timeAgo     String
  avatarColor String
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  sessionId String
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sessionId, appId])
}

model Review {
  id        String   @id @default(cuid())
  author    String
  rating    Int
  headline  String
  content   String
  timeAgo   String
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model News {
  id        String   @id @default(cuid())
  title     String
  excerpt   String
  timeAgo   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
